---
import AppLayout from '../layouts/AppLayout.astro'
import TopNavbar from '../components/shared/TopNavbar.astro'
import { UserItemsView } from '../components/items/UserItemsView'

const acceptLang = Astro.request.headers.get('accept-language') ?? ''
const lang = acceptLang.startsWith('es') ? 'es' : 'en'
---

<AppLayout title="SkinHolder - Items">
    <TopNavbar />
    <UserItemsView lang={lang} client:load />
</AppLayout>
