---
import AppLayout from '../layouts/AppLayout.astro'
import TopNavbar from '../components/shared/TopNavbar.astro'
import { ConfigPage } from '../components/pages/ConfigPage'

const acceptLang = Astro.request.headers.get('accept-language') ?? ''
const lang = acceptLang.startsWith('es') ? 'es' : 'en'
---

<AppLayout title="SkinHolder - Config">
    <TopNavbar />
    <ConfigPage lang={lang} client:load />
</AppLayout>
