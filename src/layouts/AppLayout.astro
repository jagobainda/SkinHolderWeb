---
interface Props {
    title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href="/images/logo.ico" />
        <title>{title}</title>
    </head>
    <body class="bg-gradient-to-br from-[#4A4A4A] to-[#2C2C2C] min-h-screen">
        <slot />
    </body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>
